{
  "openapi": "3.1.0",
  "info": {
    "title": "One Person Lab Web API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "x-product-layers": {
    "primary": "account_based_user_product_layer",
    "publicGrowthLayer": {
      "status": "done_v1",
      "surfaces": [
        "public_homepage",
        "use_cases",
        "task_skill_catalog",
        "example_outputs",
        "updates",
        "login_cta"
      ],
      "usesExistingAuthRoutesOnly": true,
      "cannotClaim": [
        "authenticated task success",
        "runtime execution",
        "artifact body authority",
        "full SaaS",
        "payment/team/RBAC/HA"
      ]
    },
    "minimalAdminOpsLayer": {
      "status": "partial",
      "completedSlices": [
        "registration_policy_user_status_v0"
      ],
      "nextGaps": {
        "dogfoodReleaseEvidenceSummary": "not_started",
        "hiddenOpsUi": "optional_reserved"
      },
      "registrationModeAllowed": [
        "open",
        "invite_only",
        "allowlist",
        "disabled"
      ],
      "userStatusAllowed": [
        "active",
        "disabled"
      ],
      "operatorOnlyCapabilities": [
        "view_sanitized_user_status",
        "view_quota",
        "view_audit",
        "disable_user",
        "enable_user"
      ],
      "allAdminOperationsAudited": true,
      "authBoundary": "operator_token_required",
      "forbiddenCapabilities": [
        "payment",
        "pricing",
        "subscription",
        "invoice",
        "refund",
        "team_rbac",
        "support_impersonation"
      ]
    }
  },
  "paths": {
    "/api/ops/registration-policy": {
      "get": {
        "summary": "Read operator-only registration policy.",
        "responses": {
          "200": {
            "description": "Current registration policy.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminOpsRegistrationPolicy"
                }
              }
            }
          },
          "401": {
            "description": "Operator token required."
          },
          "405": {
            "description": "Method not allowed."
          }
        }
      },
      "put": {
        "summary": "Update operator-only registration policy.",
        "responses": {
          "200": {
            "description": "Updated registration policy.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminOpsRegistrationPolicy"
                }
              }
            }
          },
          "400": {
            "description": "Invalid registration mode."
          },
          "401": {
            "description": "Operator token required."
          },
          "405": {
            "description": "Method not allowed."
          }
        }
      }
    },
    "/api/ops/users": {
      "get": {
        "summary": "List sanitized users for operator-only controls.",
        "responses": {
          "200": {
            "description": "Sanitized user summaries.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminOpsUserList"
                }
              }
            }
          },
          "401": {
            "description": "Operator token required."
          },
          "405": {
            "description": "Method not allowed."
          }
        }
      }
    },
    "/api/ops/users/{userId}/status": {
      "post": {
        "summary": "Enable or disable a user through operator-only controls.",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated sanitized user summary.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdminOpsUserSummary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid user status."
          },
          "401": {
            "description": "Operator token required."
          },
          "404": {
            "description": "User not found."
          },
          "405": {
            "description": "Method not allowed."
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register a public Web account.",
        "responses": {
          "201": {
            "description": "Registered and session cookie set."
          },
          "400": {
            "description": "Invalid JSON or credential input."
          },
          "405": {
            "description": "Method not allowed."
          },
          "409": {
            "description": "Email is already registered."
          },
          "423": {
            "description": "Registration is closed by operator policy."
          },
          "500": {
            "description": "Account could not be created."
          },
          "503": {
            "description": "Session secret is missing."
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login and set an HttpOnly session cookie.",
        "responses": {
          "200": {
            "description": "Authenticated."
          },
          "400": {
            "description": "Invalid JSON."
          },
          "401": {
            "description": "Invalid credentials."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          },
          "503": {
            "description": "Session secret is missing."
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Clear the current session.",
        "responses": {
          "204": {
            "description": "Logged out."
          },
          "405": {
            "description": "Method not allowed."
          }
        }
      }
    },
    "/api/session/current": {
      "get": {
        "summary": "Return current user session state.",
        "responses": {
          "200": {
            "description": "Current authenticated session."
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          }
        }
      }
    },
    "/api/settings/model-provider": {
      "get": {
        "summary": "Return fixed provider state without raw API key.",
        "responses": {
          "200": {
            "description": "Provider state with fixed baseUrl, readonly configured model projection, and masked key."
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          }
        }
      },
      "put": {
        "summary": "Save user API key for the fixed provider.",
        "responses": {
          "200": {
            "description": "Provider key saved without returning raw key; response includes readonly configured model projection."
          },
          "400": {
            "description": "Invalid JSON or API key."
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          },
          "500": {
            "description": "Provider key could not be saved."
          },
          "503": {
            "description": "API key encryption secret is missing."
          }
        }
      }
    },
    "/api/chat": {
      "post": {
        "summary": "Send ordinary chat through the fixed provider or return runtime gate.",
        "responses": {
          "200": {
            "description": "Assistant response."
          },
          "400": {
            "description": "Invalid JSON, message, or missing provider key."
          },
          "401": {
            "description": "Authentication required."
          },
          "404": {
            "description": "Conversation not found for current user."
          },
          "405": {
            "description": "Method not allowed."
          },
          "409": {
            "description": "Runtime required for OPL capability."
          },
          "423": {
            "description": "User is disabled by operator policy."
          },
          "429": {
            "description": "Quota exceeded before upstream call."
          },
          "502": {
            "description": "Upstream chat failed."
          },
          "503": {
            "description": "Provider key binding cannot be decrypted."
          },
          "504": {
            "description": "Upstream chat timed out."
          }
        }
      }
    },
    "/api/opl/runtime-gate": {
      "post": {
        "summary": "Check MedOPL runtime gate before runtime-required task entry.",
        "responses": {
          "200": {
            "description": "MedOPL reports runtime gate ready."
          },
          "400": {
            "description": "Invalid task intent input."
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          },
          "424": {
            "description": "MedOPL account/resource runtime gate is not ready, or OPL-Webui operator MedOPL endpoint config is missing."
          },
          "502": {
            "description": "MedOPL runtime gate upstream failed."
          },
          "504": {
            "description": "MedOPL runtime gate timed out."
          }
        }
      }
    },
    "/api/opl/runs": {
      "post": {
        "summary": "Start a MedOPL runtime-required run with refs-only Web projection.",
        "responses": {
          "200": {
            "description": "Run accepted or completed with refs/progress/deliverables projection."
          },
          "400": {
            "description": "Invalid task intent input."
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          },
          "424": {
            "description": "MedOPL account/resource runtime gate blocks the run."
          },
          "502": {
            "description": "MedOPL run upstream failed."
          },
          "504": {
            "description": "MedOPL run timed out."
          }
        }
      }
    },
    "/api/chat/conversations": {
      "get": {
        "summary": "List current user's conversations.",
        "responses": {
          "200": {
            "description": "Conversation list."
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          }
        }
      }
    },
    "/api/chat/conversations/{conversationId}": {
      "get": {
        "summary": "Read one current-user conversation.",
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversation detail."
          },
          "400": {
            "description": "Invalid conversation id."
          },
          "401": {
            "description": "Authentication required."
          },
          "404": {
            "description": "Conversation not found for current user."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          }
        }
      }
    },
    "/api/tasks": {
      "get": {
        "summary": "List current user's refs-only task history projection.",
        "responses": {
          "200": {
            "description": "Refs-only task history list.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskHistoryList"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          }
        }
      }
    },
    "/api/tasks/{taskId}": {
      "get": {
        "summary": "Read one current-user refs-only task history projection.",
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Refs-only task history detail.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskHistoryDetail"
                }
              }
            }
          },
          "400": {
            "description": "Invalid task id."
          },
          "401": {
            "description": "Authentication required."
          },
          "404": {
            "description": "Task not found for current user."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          }
        }
      }
    },
    "/api/account/audit-events": {
      "get": {
        "summary": "List current user's sanitized audit events.",
        "responses": {
          "200": {
            "description": "Sanitized user audit events."
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          }
        }
      }
    },
    "/api/account/billing-summary": {
      "get": {
        "summary": "Read current user's sanitized billing, quota, and audit projection.",
        "responses": {
          "200": {
            "description": "Sanitized billing handoff and local quota/audit summary."
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          }
        }
      }
    },
    "/api/account/commercial-status": {
      "get": {
        "summary": "Read current user's commercial account lifecycle projection.",
        "responses": {
          "200": {
            "description": "Readonly commercial account lifecycle projection.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommercialAccountStatus"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required."
          },
          "405": {
            "description": "Method not allowed."
          },
          "423": {
            "description": "User is disabled by operator policy."
          }
        }
      }
    },
    "/api/medopl/runtime/status": {
      "get": {
        "summary": "Read sanitized MedOPL runtime status projection.",
        "responses": {
          "200": {
            "description": "Readonly MedOPL runtime status projection."
          },
          "405": {
            "description": "Method not allowed."
          }
        }
      }
    },
    "/api/medopl/materials-deliverables/projection": {
      "get": {
        "summary": "Read sanitized MedOPL materials and deliverables projection.",
        "responses": {
          "200": {
            "description": "Readonly MedOPL materials and deliverables projection."
          },
          "405": {
            "description": "Method not allowed."
          }
        }
      }
    },
    "/api/opl/snapshot": {
      "get": {
        "summary": "Read OPL readonly snapshot projection.",
        "responses": {
          "200": {
            "description": "Readonly snapshot projection."
          },
          "405": {
            "description": "Method not allowed."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiErrorCode": {
        "type": "string",
        "enum": [
          "METHOD_NOT_ALLOWED",
          "AUTH_REQUIRED",
          "INVALID_JSON",
          "INVALID_CREDENTIALS_INPUT",
          "EMAIL_ALREADY_REGISTERED",
          "ACCOUNT_CREATE_FAILED",
          "INVALID_CREDENTIALS",
          "SESSION_SECRET_REQUIRED",
          "REGISTRATION_CLOSED",
          "USER_DISABLED",
          "OPERATOR_AUTH_REQUIRED",
          "INVALID_REGISTRATION_MODE",
          "INVALID_USER_STATUS",
          "USER_NOT_FOUND",
          "API_KEY_SECRET_REQUIRED",
          "INVALID_API_KEY",
          "API_KEY_SAVE_FAILED",
          "INVALID_CHAT_MESSAGE",
          "INVALID_CONVERSATION_ID",
          "CONVERSATION_NOT_FOUND",
          "INVALID_TASK_ID",
          "TASK_NOT_FOUND",
          "API_KEY_REQUIRED",
          "API_KEY_DECRYPT_FAILED",
          "RUNTIME_REQUIRED",
          "RUNTIME_GATE_BLOCKED",
          "MEDOPL_ENDPOINT_REQUIRED",
          "MEDOPL_UPSTREAM_FAILED",
          "CHAT_QUOTA_EXCEEDED",
          "UPSTREAM_CHAT_FAILED"
        ]
      },
      "TaskRef": { "type": "object", "required": ["ref"], "properties": { "ref": { "type": "string" }, "label": { "type": "string" }, "status": { "type": "string" }, "kind": { "type": "string" }, "source": { "type": "string" } }, "additionalProperties": false },
      "TaskNextAction": { "type": "object", "required": ["id", "label", "deepLink"], "properties": { "id": { "type": "string" }, "label": { "type": "string" }, "deepLink": { "type": "string" } }, "additionalProperties": false },
      "TaskBlocker": { "type": "object", "required": ["kind", "title", "deepLink"], "properties": { "kind": { "type": "string" }, "title": { "type": "string" }, "nextAction": { "type": "string" }, "deepLink": { "type": "string" } }, "additionalProperties": false },
      "TaskHistoryItem": { "type": "object", "required": ["taskId", "taskType", "taskIntent", "marker", "status", "updatedAt", "progressRefs", "deliverableRefs", "materialRefs", "nextStep", "allowedNextActions", "deeplink", "webuiArtifactBody", "webuiStorageTruth"], "properties": { "taskId": { "type": "string" }, "taskType": { "type": "string" }, "taskIntent": { "type": "string" }, "marker": { "type": "string" }, "conversationId": { "type": "string" }, "status": { "type": "string" }, "createdAt": { "type": "string" }, "updatedAt": { "type": "string" }, "progressRefs": { "type": "array", "items": { "$ref": "#/components/schemas/TaskRef" } }, "deliverableRefs": { "type": "array", "items": { "$ref": "#/components/schemas/TaskRef" } }, "materialRefs": { "type": "array", "items": { "$ref": "#/components/schemas/TaskRef" } }, "blocker": { "$ref": "#/components/schemas/TaskBlocker" }, "nextStep": { "type": "string" }, "allowedNextActions": { "type": "array", "items": { "$ref": "#/components/schemas/TaskNextAction" } }, "deeplink": { "type": "string" }, "webuiArtifactBody": { "const": "forbidden" }, "webuiStorageTruth": { "const": "forbidden" } }, "additionalProperties": false },
      "TaskHistoryList": { "type": "object", "required": ["ok", "owner", "projection", "tasks", "webuiArtifactBody", "webuiStorageTruth", "doesNotProve"], "properties": { "ok": { "type": "boolean" }, "owner": { "const": "OnePersonLabWeb" }, "projection": { "const": "refs_status_metadata_only" }, "tasks": { "type": "array", "items": { "$ref": "#/components/schemas/TaskHistoryItem" } }, "webuiArtifactBody": { "const": "forbidden" }, "webuiStorageTruth": { "const": "forbidden" }, "doesNotProve": { "type": "array", "items": { "type": "string" } } }, "additionalProperties": false },
      "TaskHistoryDetail": { "type": "object", "required": ["ok", "owner", "projection", "task", "webuiArtifactBody", "webuiStorageTruth", "doesNotProve"], "properties": { "ok": { "type": "boolean" }, "owner": { "const": "OnePersonLabWeb" }, "projection": { "const": "refs_status_metadata_only" }, "task": { "$ref": "#/components/schemas/TaskHistoryItem" }, "webuiArtifactBody": { "const": "forbidden" }, "webuiStorageTruth": { "const": "forbidden" }, "doesNotProve": { "type": "array", "items": { "type": "string" } } }, "additionalProperties": false },
      "AdminOpsRegistrationPolicy": {
        "type": "object",
        "required": [
          "ok",
          "owner",
          "registrationMode",
          "doesNotProve"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "owner": {
            "const": "OnePersonLabWeb"
          },
          "registrationMode": {
            "enum": [
              "open",
              "invite_only",
              "allowlist",
              "disabled"
            ]
          },
          "doesNotProve": {
            "type": "array",
            "items": {
              "enum": [
                "full SaaS",
                "payment lifecycle",
                "team/RBAC lifecycle",
                "HA",
                "runtime sync"
              ]
            }
          }
        },
        "additionalProperties": false
      },
      "AdminOpsUserSummary": {
        "type": "object",
        "required": [
          "userId",
          "email",
          "tenantId",
          "workspaceId",
          "userStatus",
          "createdAt",
          "quota",
          "auditSummary"
        ],
        "properties": {
          "userId": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "tenantId": {
            "type": "string"
          },
          "workspaceId": {
            "type": "string"
          },
          "userStatus": {
            "enum": [
              "active",
              "disabled"
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "quota": {
            "type": "object",
            "required": [
              "limit",
              "used",
              "remaining"
            ],
            "properties": {
              "limit": {
                "type": "integer"
              },
              "used": {
                "type": "integer"
              },
              "remaining": {
                "type": "integer"
              }
            },
            "additionalProperties": false
          },
          "auditSummary": {
            "type": "object",
            "required": [
              "eventCount",
              "latestEventKind"
            ],
            "properties": {
              "eventCount": {
                "type": "integer"
              },
              "latestEventKind": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "AdminOpsUserList": {
        "type": "object",
        "required": [
          "ok",
          "owner",
          "users",
          "doesNotProve"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "owner": {
            "const": "OnePersonLabWeb"
          },
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdminOpsUserSummary"
            }
          },
          "doesNotProve": {
            "type": "array",
            "items": {
              "enum": [
                "full SaaS",
                "payment lifecycle",
                "team/RBAC lifecycle",
                "HA",
                "runtime sync"
              ]
            }
          }
        },
        "additionalProperties": false
      },
      "SanitizedAuditEvent": {
        "type": "object",
        "required": [
          "type",
          "createdAt"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      },
      "CommercialAccountStatus": {
        "type": "object",
        "required": [
          "ok",
          "owner",
          "productId",
          "accountType",
          "lifecycleState",
          "tenantId",
          "tenantRole",
          "teamReadiness",
          "webuiTeamMutation",
          "webuiInviteMutation",
          "webuiRBACMutation",
          "webuiPaymentMutation",
          "webuiBillingSourceOfTruth"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "owner": {
            "const": "OnePersonLabWeb"
          },
          "productId": {
            "const": "one-person-lab-web"
          },
          "accountType": {
            "enum": [
              "personal"
            ]
          },
          "lifecycleState": {
            "enum": [
              "active"
            ]
          },
          "tenantId": {
            "type": "string"
          },
          "tenantRole": {
            "enum": [
              "owner"
            ]
          },
          "teamReadiness": {
            "type": "object",
            "required": [
              "state",
              "owner",
              "consumer",
              "allowedNextActions"
            ],
            "properties": {
              "state": {
                "enum": [
                  "single_user_owner"
                ]
              },
              "owner": {
                "const": "OnePersonLabWeb"
              },
              "consumer": {
                "const": "settings_lifecycle_summary"
              },
              "allowedNextActions": {
                "type": "array",
                "items": {
                  "enum": [
                    "view_medopl_billing"
                  ]
                }
              }
            },
            "additionalProperties": false
