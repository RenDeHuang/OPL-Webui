  "provider": {
    "id": "gflabtoken",
    "fixedBaseUrl": "https://gflabtoken.cn/v1",
    "wireApi": "responses",
    "defaultModel": "gpt-5.5",
    "serviceTier": "fast",
    "reasoningEffort": "xhigh",
    "upstreamTimeoutSeconds": 60,
    "upstreamTimeoutEnv": "OPL_CHAT_UPSTREAM_TIMEOUT_SECONDS",
    "userEditableBaseUrl": false,
    "clientMaySendBaseUrl": false
  },
  "credential": {
    "rawKeyReturnedToBrowser": false,
    "rawKeyLogged": false,
    "storageRequirement": "encrypted_server_side"
  },
  "publicUi": {
    "primarySurface": "ai_native_research_homepage",
    "hiddenConcepts": ["workspace", "runtime", "nodePool", "storage", "billing"],
    "visibleRoutes": ["home", "skills", "workflows", "projects", "more"]
  },
  "visionGaps": {
    "state": "active_non_ha_gap_acceptance",
    "haPolicy": {
      "state": "paused",
      "reason": "single-node launch safety"
    },
    "items": [
      {
        "id": "ui_ux_product_depth",
        "ownerSurface": "apps-web",
        "acceptanceContract": "contracts/web-gui-product-contract.json",
        "disposition": "production_ui_quality_claim_pending_owner_receipt_and_production_evidence",
        "evidenceRequired": [
          "figma_mcp_source_context",
          "component_state_contract",
          "responsive_shell_smoke",
          "browser_interaction_e2e",
          "desktop_tablet_mobile_compact_visual_qa_browser_evidence",
          "human_owner_receipt_before_production_ui_claim",
          "production_browser_e2e_or_screenshot_evidence",
          "accessibility_closeout_boundary",
          "sanitized_foldback"
        ]
      },
      {
        "id": "medopl_readonly_evidence",
        "ownerSurface": "release-evidence",
        "acceptanceContract": "contracts/web-release-profile.json#/productionDogfoodReadiness",
        "disposition": "awaiting_secret_gated_foldback",
        "evidenceRequired": [
          "readonly_switch_confirmed",
          "sanitized_dogfood_stdout_foldback",
          "raw_secret_absence"
        ]
      },
      {
        "id": "runtime_execution_boundary",
        "ownerSurface": "runtime-gate",
        "acceptanceContract": "contracts/web-runtime-bridge.json",
        "disposition": "fail_closed_until_admission_contract",
        "evidenceRequired": [
          "go_side_execution_contract",
          "registered_eval",
          "command_allowlist",
          "human_authorization_boundary"
        ]
      },
      {
        "id": "commercial_saas_depth",
        "ownerSurface": "product-boundary",
        "acceptanceContract": "contracts/web-product-profile.json#/commercialLifecycle",
        "disposition": "readonly_personal_projection_only",
        "evidenceRequired": [
          "real_consumer",
          "contract",
          "registered_tests",
          "MedOPL_billing_authority_preserved"
        ]
      },
      {
        "id": "operations_maturity",
        "ownerSurface": "release-evidence",
        "acceptanceContract": "contracts/web-release-profile.json#/productionObservabilityBaseline",
        "disposition": "baseline_plus_next_evidence_contracts",
        "evidenceRequired": [
          "dashboard_contract",
          "alerting_contract",
          "error_budget_contract",
          "rollback_record_contract"
        ]
      }
    ]
  },
  "commercialLifecycle": {
    "mode": "authenticated_readonly_personal_status_projection",
    "currentPhase": "commercial_contract",
    "nextPhase": "commercial_consumer_contract",
    "blockedBy": "missing_product_decision",
