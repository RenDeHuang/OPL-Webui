      "required": true,
      "source": "external_owner"
    },
    "owner": "one-person-lab-web",
    "consumer": "settings_lifecycle_summary",
    "contract": "contracts/web-api.openapi.json#/paths/~1api~1account~1commercial-status",
    "currentAccountType": "personal",
    "currentLifecycleState": "active",
    "projectionOnly": true,
    "webRoutesMayMutateBilling": false,
    "allowedCurrentActions": ["view_medopl_billing"],
    "expansionRequires": [
      "real_consumer",
      "contract",
      "registered_tests",
      "MedOPL_billing_authority_preserved"
    ],
    "expansionConditions": [
      {
        "id": "real_consumer",
        "status": "missing",
        "owner": "external_owner",
        "evidence": "owner_receipt"
      },
      {
        "id": "surface_contract",
        "status": "missing",
        "owner": "one-person-lab-web-product",
        "evidence": "contract"
      },
      {
        "id": "registered_tests",
        "status": "missing",
