    "e2eStateMatrix": [
      {
        "id": "ordinary_path",
        "owner": "OPL-Webui",
        "runtimeStorageRequired": false,
        "requiredTruth": ["OPL-Webui session/account projection"],
        "cannotClaim": ["runtime truth", "storage truth", "billing truth"]
      },
      {
        "id": "specialist_blocked_onboarding",
        "owner": "MedOPL",
        "runtimeStorageRequired": true,
        "requiresMedoplProjection": true,
        "requiresDeeplink": true,
        "states": ["account not approved", "balance insufficient", "plan missing", "runtime/storage not ready"]
      },
      {
        "id": "specialist_ready",
        "owner": "MedOPL",
        "runtimeStorageRequired": true,
        "readyRequires": [
          "MedOPL approved account",
          "MedOPL plan",
          "MedOPL balance/quota",
          "MedOPL runtime ready",
          "MedOPL storage ready"
        ],
        "webuiMode": "readonly ready projection plus refs/deeplink continuation"
      }
    ],
    "dynamicSyncTriggers": [
      "public_contract_changed",
      "current_truth_or_next_recommended_goal_changed",
      "can_claim_or_cannot_claim_changed",
      "payment_psp_billing_runtime_storage_release_boundary_changed",
      "opl_webui_projection_deeplink_runtime_bridge_changed",
      "ha_rollback_production_evidence_or_broader_tenant_canary_completed",
      "live_e2e_evidence_added_or_expired"
    ],
    "failClosedRule": {
      "onMismatch": true,
      "blockedActions": ["live_e2e", "rollout", "production_complete_claim"],
      "mismatchReportFields": [
        "ownership_conflict",
        "claim_inconsistency",
        "head_mismatch",
        "contract_field_missing",
        "cannot_claim_upgraded"
      ]
    },
    "validationGate": {
      "webui": ["npm run verify:contract", "npm run verify:health", "npm run verify"],
      "medopl": ["npm run verify", "npm run test:health", "npm run test:contract"],
      "crossRepo": "fresh read both remote HEADs and contract pointers before claiming E2E readiness"
    },
    "nextLiveE2EPrerequisites": [
      "MedOPL release metadata / rollback maturity",
      "OPL-Webui HA / resilience / error-budget readiness",
      "future PSP goal before payment-to-runtime E2E"
    ],
    "canClaim": [
      "dynamic cross-repo current truth readout is defined at contract level",
      "remote HEAD and owner boundary are recorded for this sync",
      "mismatches fail closed before live E2E, rollout, or production-complete claims"
    ],
    "cannotClaim": [
      "live E2E executed by this sync",
      "rollout executed by this sync",
      "production complete",
      "external PSP settlement",
      "all users/all tenants",
      "SLA/multi-region"
    ],
    "retirement": {
      "closeoutAfterSync": true,
      "longTermActiveBlocker": false,
      "rerunPolicy": "rerun this sync goal or follow-up sync when any dynamicSyncTriggers item changes"
    }
  },
  "doesNotProve": [
    "production rollout",
    "MedOPL readiness",
    "payment readiness",
    "billing source of truth",
    "runtime execution",
    "storage truth",
    "resource-control truth",
    "full SaaS capability"
  ]
