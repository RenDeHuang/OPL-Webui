    "apply": {
      "entrypoint": "node scripts/cloud-rollout.mjs --apply",
      "requiresImage": true,
      "requiresKubeconfig": true,
      "requiresEnvironmentApproval": true,
      "mutatesCluster": true
    },
    "canarySmoke": {
      "runsInsideApply": true,
      "checks": [
        "canary db",
        "canary opl-cli",
        "HTTPS /healthz",
        "HTTPS /readyz",
        "HTTPS /metricsz",
        "HTTPS /"
      ],
      "semanticJsonChecks": [
        "/readyz ok=true missing=[]",
        "/metricsz ok=true missingDependencyCount=0"
      ]
    }
  },
