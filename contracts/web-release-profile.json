{
  "schemaVersion": 1,
  "productId": "one-person-lab-web",
  "currentStage": "one-person-lab-web-contract-truth",
  "productionHost": "opl.medopl.cn",
  "requiredEnvKeys": [
    "OPL_DATABASE_URL",
    "OPL_TENANT_AUTH_SECRET",
    "OPL_SESSION_SECRET",
    "OPL_API_KEY_ENCRYPTION_SECRET",
    "OPL_CHAT_MODEL"
  ],
  "requiredGates": [
    "npm run verify",
    "npm run gate:review",
    "npm run repo:bloat",
    "sentrux check ."
  ],
  "dogfood": {
    "defaultEnabled": false,
    "rawApiKeyPrinted": false,
    "switches": [
      "OPL_PRODUCTION_DOGFOOD_E2E",
      "OPL_DOGFOOD_EMAIL",
      "OPL_DOGFOOD_PASSWORD",
      "OPL_DOGFOOD_API_KEY",
      "OPL_PRODUCTION_DOGFOOD_REAL_CHAT"
    ]
  },
  "rolloutPipeline": {
    "mode": "dry_run_first_apply_canary_smoke_then_dogfood",
    "orderedStages": [
      "production_dry_run",
      "production_apply",
      "canary_smoke",
      "production_authenticated_dogfood"
    ],
    "dryRun": {
      "entrypoint": "node scripts/cloud-rollout.mjs",
      "requiresImage": true,
      "requiresKubeconfig": false,
      "mutatesCluster": false
    },
    "apply": {
      "entrypoint": "node scripts/cloud-rollout.mjs --apply",
      "requiresImage": true,
      "requiresKubeconfig": true,
      "requiresEnvironmentApproval": true,
      "mutatesCluster": true
    },
    "canarySmoke": {
      "runsInsideApply": true,
      "checks": [
        "canary db",
        "canary opl-cli",
        "HTTPS /healthz",
        "HTTPS /readyz",
        "HTTPS /metricsz",
        "HTTPS /"
      ],
      "semanticJsonChecks": [
        "/readyz ok=true missing=[]",
        "/metricsz ok=true missingDependencyCount=0"
      ]
    }
  },
  "productionDogfoodReadiness": {
    "mode": "secret_gated_http_authenticated_e2e",
    "state": "configured_not_executed_in_this_phase",
    "defaultEnabled": false,
    "requiresProductionSecrets": true,
    "requiresSuccessfulRolloutEvidence": true,
    "afterStage": "production_apply_canary_smoke",
    "browserAutomation": false,
    "entrypoint": "node scripts/cloud-rollout.mjs --dogfood-e2e",
    "workflow": ".github/workflows/cloud-rollout.yml",
    "environment": "production",
    "requiredSecrets": [
      "OPL_DOGFOOD_EMAIL",
      "OPL_DOGFOOD_PASSWORD",
      "OPL_DOGFOOD_API_KEY"
    ],
    "secretValidation": {
      "OPL_DOGFOOD_EMAIL": "must contain @",
      "OPL_DOGFOOD_PASSWORD": "min_length_12"
    },
    "requiredSwitches": [
      "OPL_PRODUCTION_DOGFOOD_E2E"
    ],
    "optionalSwitches": [
      "OPL_PRODUCTION_DOGFOOD_REAL_CHAT"
    ],
    "forbiddenSecrets": [
      "KUBECONFIG",
      "OPL_DATABASE_URL",
      "PGPASSWORD",
      "MEDOPL_TOKEN",
      "TCR_PASSWORD"
    ],
    "coverage": [
      "register_or_login",
      "current_session",
      "api_key_binding",
      "fixed_gateway",
      "raw_api_key_not_returned",
      "ordinary_chat_optional_real_quota",
      "runtime_gate_audit",
      "sanitized_audit"
    ],
    "cannotClaim": [
      "browser e2e",
      "MedOPL runtime execution",
      "quota exhaustion production evidence",
      "billing source of truth",
      "storage or node pool mutation"
    ]
  },
  "localNoSecretReadiness": {
    "requiresProductionSecrets": false,
    "browserAutomation": false,
    "automationLevel": "http_contract_and_static_shell",
    "coverage": [
      "register",
      "login",
      "current_session",
      "browser_session_bootstrap",
      "api_key_binding",
      "ordinary_chat_mock_upstream",
      "quota_exceeded",
      "runtime_gate",
      "sanitized_audit",
      "desktop_shell",
      "mobile_shell",
      "settings_hash"
    ],
    "evidenceCommands": [
      "node --test tests/contract/one-person-lab-chat-upstream.test.mjs",
      "node --test tests/contract/go-control-plane-http.test.mjs",
      "node --test tests/contract/one-person-lab-web-data.test.mjs",
      "node --test tests/smoke/web-shell.test.mjs"
    ],
    "cannotClaim": [
      "production authenticated dogfood e2e executed",
      "real upstream/API Key online dogfood",
      "production quota exhaustion online evidence",
      "MedOPL production runtime bridge",
      "real OPL execution or mutation"
    ]
  },
  "historicalEvidenceRefs": [
    "docs/history/process/closeouts.md",
    "deploy/web-cloud/RUNBOOK.md"
  ],
  "cannotClaim": [
    "complete production-ready SaaS",
    "production authenticated dogfood e2e executed in this phase",
    "real OPL runtime execution",
    "MedOPL runtime bridge implementation",
    "billing source of truth"
  ]
}
