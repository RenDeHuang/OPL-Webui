      "allowedInputs": [
        "full_tcr_tag",
        "full_tcr_sha256_digest",
        "release_short_commit_tag"
      ],
      "repository": "uswccr.ccs.tencentyun.com/webopl/opl-webui",
      "shortCommitTagPattern": "^[0-9a-f]{7,40}$",
      "normalization": "release_short_commit_tag maps to uswccr.ccs.tencentyun.com/webopl/opl-webui:<tag>",
      "forbiddenInputs": [
        "external_registry",
        "unscoped_repository",
        "floating_latest_tag"
      ]
    },
    "orderedStages": [
      "production_dry_run",
      "production_image_preflight",
      "production_apply",
      "canary_smoke",
      "production_authenticated_dogfood"
    ],
    "dryRun": {
      "entrypoint": "node scripts/cloud-rollout.mjs",
      "requiresImage": true,
      "requiresKubeconfig": false,
      "mutatesCluster": false
    },
    "imagePreflight": {
      "entrypoint": "node scripts/cloud-rollout.mjs --image-preflight",
      "requiresImage": true,
      "requiresKubeconfig": false,
      "mutatesCluster": false,
      "registryAuth": "private_tcr_manifest_read",
      "requiredSecrets": [
        "TCR_USERNAME",
        "TCR_PASSWORD"
      ],
      "forbiddenSecrets": [
        "KUBECONFIG",
        "OPL_DATABASE_URL",
        "PGPASSWORD",
        "OPL_DOGFOOD_API_KEY",
        "OPL_DOGFOOD_PASSWORD",
        "MEDOPL_TOKEN"
      ],
      "afterStage": "production_dry_run",
      "beforeStage": "production_apply",
      "failureKind": "image_missing_rollout_order_issue",
      "imagePullOccurredOnFailure": false
    },
    "apply": {
      "entrypoint": "node scripts/cloud-rollout.mjs --apply",
      "requiresImage": true,
      "requiresKubeconfig": true,
      "requiresEnvironmentApproval": true,
      "mutatesCluster": true
    },
    "canarySmoke": {
      "runsInsideApply": true,
      "checks": [
        "canary db",
        "canary opl-cli",
        "HTTPS /healthz",
        "HTTPS /readyz",
        "HTTPS /metricsz",
        "HTTPS /"
      ],
      "semanticJsonChecks": [
        "/readyz ok=true missing=[]",
        "/metricsz ok=true missingDependencyCount=0"
      ]
    }
  },
