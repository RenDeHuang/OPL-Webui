        "canary db",
        "canary opl-cli",
        "HTTPS /healthz",
        "HTTPS /readyz",
        "HTTPS /metricsz",
        "HTTPS /"
      ],
      "semanticJsonChecks": [
        "/readyz ok=true missing=[]",
        "/metricsz ok=true missingDependencyCount=0"
      ]
    }
  },
