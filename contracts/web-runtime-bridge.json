{
  "schemaVersion": 1,
  "productId": "one-person-lab-web",
  "owner": "MedOPL",
  "mode": "gate_and_readonly_projection_v1",
  "webuiRuntimeExecution": "forbidden",
  "medoplDeepLink": "https://medopl.medopl.cn",
  "runtimeRequiredMarkers": ["@论文", "@基金", "@综述", "@文件"],
  "lightweightMarkers": ["@科研"],
  "markerSemantics": [
    {
      "marker": "@科研",
      "workflow": "research_planning",
      "runtimePolicy": "ordinary_chat_fallback"
    },
    {
      "marker": "@论文",
      "workflow": "paper_review_workflow",
      "runtimePolicy": "runtime_gate"
    },
    {
      "marker": "@基金",
      "workflow": "grant_workflow",
      "runtimePolicy": "runtime_gate"
    },
    {
      "marker": "@综述",
      "workflow": "review_workflow",
      "runtimePolicy": "runtime_gate"
    },
    {
      "marker": "@文件",
      "workflow": "materials_refs_workflow",
      "runtimePolicy": "runtime_gate"
    }
  ],
  "forbiddenActions": [
    "opl_install",
    "opl_repair",
    "opl_module_exec",
    "family_runtime_mutation",
    "engine_install",
    "engine_update",
    "engine_remove",
    "private_state_read",
    "runtime_mutation"
  ],
  "projectionPolicy": {
    "allowedPayload": [
      "refs",
      "status",
      "counts",
      "progress_refs",
      "deliverable_refs"
    ],
    "forbiddenPayload": [
      "artifact_body",
      "memory_body",
      "domain_verdict",
      "private_state_path",
      "mutation_result",
      "raw_provider_secret"
    ]
  },
  "authorizationBoundary": {
    "requiresGoSideContract": true,
    "requiresEval": true,
    "requiresWhitelist": true,
    "requiresHumanAuthorization": true
  },
  "executionAdmission": {
    "currentStatus": "not_admitted",
    "currentPhase": "execution_admission",
    "nextPhase": "runtime_execution_contract_design",
    "blockedBy": "missing_owner_receipt",
    "ownerReceipt": {
      "required": true,
      "source": "human_owner_receipt"
    },
    "nextStepOpeners": [
      "human owner receipt names the real consumer and command class",
      "Go-side runtime execution contract is added",
      "registered eval covers command allowlist and authorization boundary"
    ],
    "requiredBeforeAnyExecution": [
      "Go-side runtime execution contract",
      "registered eval covering command allowlist",
      "human authorization boundary",
      "tenant-scoped audit events",
      "artifact/body authority contract"
    ],
    "failClosedUntil": [
      "contract_exists",
      "eval_passes",
      "allowlist_exists",
      "authorization_boundary_exists"
    ]
  }
}
