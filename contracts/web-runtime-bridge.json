{
  "schemaVersion": 1,
  "productId": "one-person-lab-web",
  "owner": "MedOPL",
  "mode": "gate_and_readonly_projection_v1",
  "webuiRuntimeExecution": "forbidden",
  "medoplDeepLink": "https://medopl.medopl.cn",
  "medoplApiBridge": {
    "mode": "go_control_plane_to_medopl_api_bridge_v1",
    "owner": "one-person-lab-web-control-plane",
    "consumer": "opl-webui-browser",
    "upstreamOwner": "MedOPL",
    "requiredEndpointEnv": "MEDOPL_API_BASE_URL",
    "endpointNotConfiguredPolicy": "fail_closed_typed_blocker",
    "routes": {
      "runtimeGate": {
        "webRoute": "POST /api/opl/runtime-gate",
        "upstreamRoute": "POST /api/opl/runtime-gate",
        "owner": "MedOPL",
        "requestPolicy": "task_intent_workspace_runtime_user_context_only",
        "readyRequiredBeforeRun": true
      },
      "runs": {
        "webRoute": "POST /api/opl/runs",
        "upstreamRoute": "POST /api/opl/runs",
        "owner": "MedOPL",
        "requestPolicy": "task_intent_workspace_runtime_refs_user_account_context_only",
        "projectionPolicy": "refs_progress_deliverables_blocker_only"
      },
      "billingSummary": {
        "webRoute": "GET /api/account/billing-summary",
        "upstreamRoute": "GET /api/billing/summary",
        "owner": "MedOPL",
        "projectionPolicy": "readonly_summary_and_ledger_refs_only"
      }
    },
    "typedBlockers": [
      "api_key_required",
      "package_required",
      "compute_required",
      "storage_required",
      "workspace_runtime_binding_required",
      "billing_blocked",
      "release_required",
      "audit_required",
      "medopl_endpoint_required"
    ],
    "forbiddenResponseFields": [
      "artifactBody",
      "artifact_body",
      "domainVerdict",
      "rawProviderKey",
      "apiKey",
      "providerApiKey",
      "bearerToken",
      "launchToken",
      "runtimeToken",
      "kubeconfig",
      "signedUrl",
      "objectKey",
      "storageKey",
      "localPath"
    ],
    "cannotClaim": [
      "MedOPL production runtime execution",
      "billing source of truth",
      "storage mutation",
      "artifact body authority",
      "domain truth"
    ]
  },
  "capabilityGoal": {
    "mode": "medopl_authorized_capability_entry_and_refs_projection",
    "userCapabilities": [
      "runtime",
      "storage",
      "progress_refs",
      "deliverable_refs",
      "materials_refs",
      "presentation_refs",
      "book_refs"
    ],
    "webRole": [
      "gate",
      "authorization_status",
      "readonly_projection",
      "progress_refs_projection",
      "deliverable_refs_projection",
      "deeplink"
    ],
    "authorityOwners": [
      "MedOPL",
      "OPL Framework"
    ],
    "claimBoundary": "Web can call MedOPL runtime gate/run bridge and expose authorized capability entry plus sanitized blockers, refs, progress, deliverables, status, and ledger refs only; it cannot execute runtime commands, own storage truth, mutate billing, or return artifact bodies."
  },
  "runtimeRequiredMarkers": ["@论文", "@基金", "@综述", "@文件", "@PPT", "@书"],
  "lightweightMarkers": ["@科研"],
  "markerSemantics": [
    {
      "marker": "@科研",
      "workflow": "research_planning",
      "runtimePolicy": "ordinary_chat_fallback"
    },
    {
      "marker": "@论文",
      "workflow": "paper_review_workflow",
      "runtimePolicy": "runtime_gate"
    },
    {
      "marker": "@基金",
      "workflow": "grant_workflow",
      "runtimePolicy": "runtime_gate"
    },
    {
      "marker": "@综述",
      "workflow": "review_workflow",
      "runtimePolicy": "runtime_gate"
    },
    {
      "marker": "@文件",
      "workflow": "materials_refs_workflow",
      "runtimePolicy": "runtime_gate"
    },
    {
      "marker": "@PPT",
      "workflow": "presentation_foundry_workflow",
      "runtimePolicy": "runtime_gate"
    },
    {
      "marker": "@书",
      "workflow": "book_foundry_workflow",
      "runtimePolicy": "runtime_gate"
    }
  ],
  "forbiddenActions": [
    "opl_install",
    "opl_repair",
    "opl_module_exec",
    "family_runtime_mutation",
    "engine_install",
    "engine_update",
    "engine_remove",
    "private_state_read",
    "runtime_mutation"
  ],
  "projectionPolicy": {
    "allowedPayload": [
      "refs",
      "status",
      "counts",
      "progress_refs",
      "deliverable_refs"
    ],
    "forbiddenPayload": [
      "artifact_body",
      "memory_body",
      "domain_verdict",
      "private_state_path",
      "mutation_result",
      "raw_provider_secret"
    ]
  },
  "authorizationBoundary": {
    "requiresGoSideContract": true,
    "requiresEval": true,
    "requiresWhitelist": true,
    "requiresHumanAuthorization": true
  },
  "executionAdmission": {
    "currentStatus": "not_admitted",
    "currentPhase": "execution_admission",
    "nextPhase": "production_medopl_runtime_evidence_closeout",
    "blockedBy": null,
    "ownerReceipt": {
      "required": true,
      "source": "human_owner_receipt",
      "status": "accepted",
      "acceptedAt": "2026-06-26",
      "acceptedClaim": "medopl_runtime_gate_run_bridge_local_refs_only_accepted",
      "acceptedScope": "Web may bridge MedOPL runtime gate and run refs/progress/deliverables locally; MedOPL and OPL Framework remain execution and artifact authority."
    },
    "authority": {
      "execution": ["MedOPL", "OPL Framework"],
      "billing": ["MedOPL"],
      "storage": ["MedOPL"],
      "artifactBody": ["MedOPL", "OPL Framework"],
      "web": ["runtime_gate_bridge", "run_intent_submitter", "typed_blocker_projection", "refs_progress_deliverables_projection", "billing_ledger_refs_projection"],
      "webIsExecutionOwner": false
    },
    "currentAllowlist": [],
    "forbiddenCommands": ["install", "repair", "module_exec", "artifact_body", "runtime_mutation"],
    "nextStepOpeners": [
      "production MedOPL endpoint is configured",
      "production runtime gate/run evidence is folded back",
      "artifact/body authority contract stays external"
    ],
    "requiredBeforeAnyExecution": [
      "production MedOPL runtime execution evidence",
      "registered bridge eval",
      "human authorization boundary",
      "tenant-scoped audit events",
      "artifact/body authority contract"
    ],
    "conditions": [
      {
        "id": "go_side_medopl_bridge_contract",
        "status": "present",
        "owner": "one-person-lab-web-runtime",
        "evidence": "contracts/web-runtime-bridge.json#/medoplApiBridge"
      },
      {
        "id": "registered_bridge_eval",
        "status": "pass",
        "owner": "one-person-lab-web-runtime",
        "evidence": "tests/contract/medopl-runtime-bridge-contract.test.mjs"
      },
      {
        "id": "command_allowlist",
        "status": "present",
        "owner": "one-person-lab-web-runtime",
        "evidence": "empty_allowlist"
      },
      {
        "id": "human_authorization_boundary",
        "status": "accepted",
        "owner": "human_owner_receipt",
        "evidence": "owner_receipt"
      },
      {
        "id": "tenant_scoped_audit_events",
        "status": "partial",
        "owner": "one-person-lab-web-runtime",
        "evidence": "runtime_gate_audit_only"
      },
      {
        "id": "production_medopl_runtime_execution_evidence",
        "status": "missing",
        "owner": "release-evidence",
        "evidence": "release_evidence"
      },
      {
        "id": "artifact_body_authority_contract",
        "status": "missing",
        "owner": "MedOPL",
        "evidence": "authority_contract"
      }
    ],
    "admittedWhen": [
      "go_side_medopl_bridge_contract=present",
      "registered_bridge_eval=pass",
      "command_allowlist=present",
      "human_authorization_boundary=accepted",
      "tenant_scoped_audit_events=present",
      "production_medopl_runtime_execution_evidence=present",
      "artifact_body_authority_contract=present"
    ],
    "webRoutesMayMutateRuntime": false,
    "failClosedUntil": [
      "MEDOPL_API_BASE_URL_configured",
      "gate_ready",
      "bridge_eval_passes",
      "authorization_boundary_exists"
    ]
  }
}
