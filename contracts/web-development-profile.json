{
  "schemaVersion": 1,
  "productId": "one-person-lab-web",
  "owner": "product-engineering owner",
  "purpose": "machine-readable AI development discipline for production-grade Web work",
  "state": "active_policy",
  "machineBoundary": "AI workflow gate input; docs explain this contract but do not replace it",
  "taskTiers": [
    {
      "id": "direct",
      "description": "Read-only analysis, status explanation, or planning without repository mutation.",
      "mayModifyRepository": false,
      "requiredEvidence": [
        "source links or local file references when making factual claims"
      ],
      "forbiddenClaims": [
        "implementation complete",
        "production ready",
        "owner accepted"
      ]
    },
    {
      "id": "inline",
      "description": "Small source, contract, test, or docs change with one owner surface and local verification.",
      "mayModifyRepository": true,
      "requiresWorktree": false,
      "requiredEvidence": [
        "targeted lane",
        "npm run verify",
        "npm run gate:review when review or completion is claimed"
      ]
    },
    {
      "id": "durable",
      "description": "Production, deploy, browser e2e, runtime, billing, storage, security, or long-running cross-surface work.",
      "mayModifyRepository": true,
      "requiresWorktree": true,
      "requiredEvidence": [
        "allowed write set",
        "forbidden write set",
        "targeted lane",
        "npm run verify",
        "npm run gate:review",
        "npm run repo:bloat",
        "sentrux check .",
        "release evidence foldback when production state changes"
      ]
    }
  ],
  "requiredOrder": [
    "readFixedTruth",
    "selectOneGap",
    "declareOwnerSurface",
    "updateContractWhenNeeded",
    "registerTests",
    "implement",
    "retireReplacedSurfaces",
    "runTargetedLane",
    "runCurrentVerify",
    "foldBackEvidence",
    "declareCanAndCannotClaim"
  ],
  "fixedTruth": [
    "README.md",
    "AGENTS.md",
    "TASTE.md",
    "docs/project.md",
    "docs/status.md",
    "docs/decisions.md",
    "docs/architecture.md",
    "docs/invariants.md",
    "docs/docs_portfolio_consolidation.md",
    "docs/active/README.md",
    "contracts/web-product-profile.json",
    "contracts/web-page-state-matrix.json",
    "contracts/web-api.openapi.json",
    "contracts/web-runtime-bridge.json",
    "contracts/web-release-profile.json",
    "contracts/web-development-profile.json",
    "contracts/web-surface-inventory.json"
  ],
  "claimProofQuestions": [
    "whatClaimChanged",
    "whoOwnsTheClaim",
    "whoConsumesTheSurface",
    "whereIsTheContract",
    "whichTestProofCoversIt",
    "whatProofLevelApplies",
    "whatCannotBeClaimed",
    "whetherProductionEvidenceWasFoldedBack",
    "whetherNewSurfaceCanRetire"
  ],
  "contractFirstSurfaces": {
    "appsWeb": [
      "contracts/web-page-state-matrix.json",
      "contracts/web-product-profile.json"
    ],
    "publicApi": [
      "contracts/web-api.openapi.json"
    ],
    "runtimeGate": [
      "contracts/web-runtime-bridge.json"
    ],
    "releaseClaim": [
      "contracts/web-release-profile.json"
    ],
    "developmentWorkflow": [
      "contracts/web-development-profile.json",
      "contracts/web-surface-inventory.json",
      "scripts/test-classification.mjs",
      "scripts/lane-advisory.mjs",
      "scripts/lane-check.mjs",
      "scripts/ai-development-gate.mjs"
    ]
  },
  "bloatPolicy": {
    "newSurfaceRequires": [
      "ownerSurface",
      "consumer",
      "contractOrMachineBoundary",
      "testOrGate",
      "retirementRuleWhenTemporary"
    ],
    "forbid": [
      "orphanDocs",
      "orphanTests",
      "compatLayerWithoutConsumer",
      "fakeRuntimeClaim",
      "productionClaimWithoutFreshEvidence",
      "historicalRunLogsInActiveDocs"
    ],
    "fileCountMode": "report_only",
    "hardFailures": [
      "lineBudget",
      "retiredSurface",
      "testRegistry",
      "contractViolation",
      "staleClaim",
      "orphanSurface"
    ]
  },
  "surfaceInventoryPolicy": {
    "inventory": "contracts/web-surface-inventory.json",
    "scope": "long_lived_surfaces_only",
    "register": [
      "scripts/*.mjs",
      "contracts/*.json",
      "tests/**/*.test.mjs",
      "Go *_test.go",
      "recurring docs",
      "workflows/deploy surfaces",
      "selected source owner surfaces"
    ],
    "doNotRegister": [
      "ordinary implementation files",
      "generated output",
      "temporary logs",
      "coverage",
      "runtime artifacts"
    ],
    "requiredFields": [
      "path",
      "type",
      "ownerSurface",
      "consumer",
      "contract or machineBoundary",
      "lifecycle",
      "retirement when temporary or tombstone"
    ]
  },
  "testProofPolicy": {
    "definition": "Test is executable evidence for a specific claim.",
    "requiredRegistryFields": [
      "testKind",
      "proofLevel",
      "claimScope",
      "proves",
      "doesNotProve"
    ],
    "testKinds": [
      "acceptance",
      "contract",
      "governance",
      "regression"
    ],
    "proofLevels": [
      "static",
      "unit",
      "http",
      "browser",
      "production"
    ],
    "claimScopes": [
      "repo",
      "local",
      "ci",
      "production"
    ],
    "rule": "lower proof levels cannot support higher environment or production claims unless fresh higher-level evidence is folded back"
  },
  "completionPolicy": {
    "docsOnlyCannotComplete": true,
    "testsOnlyCannotClaimProduction": true,
    "contractOnlyCannotClaimRuntimeReady": true,
    "schemaOnlyCannotClaimRuntimeReady": true,
    "providerHealthyCannotClaimDomainQuality": true,
    "productionClaimRequiresFreshRun": true,
    "failedProductionRunRequiresFoldback": true
  },
  "triggerPolicy": {
    "everyFormalDevelopment": [
      "npm run gate:ai",
      "targeted lane from scripts/lane-advisory.mjs"
    ],
    "reviewOrCompletion": [
      "npm run gate:review"
    ],
    "productionRunCompleted": [
      "node scripts/release-evidence-sync.mjs --run-id <github-run-id>",
      "foldback to contracts/web-release-profile.json and docs/status.md"
    ],
    "newTest": [
      "register in scripts/test-classification.mjs",
      "declare lane, ownerSurface, lifecycleRole, cost, riskTriggers, contracts, verifySuites",
      "declare testKind, proofLevel, claimScope, proves, doesNotProve"
    ],
    "newLongLivedSurface": [
      "register in contracts/web-surface-inventory.json",
      "declare ownerSurface, consumer, contract or machineBoundary, lifecycle, and retirement when temporary",
      "run npm run repo:bloat"
    ]
  }
}
