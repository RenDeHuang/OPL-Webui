{
  "schemaVersion": 1,
  "productId": "one-person-lab-web",
  "routes": [
    {
      "id": "home",
      "hash": "",
      "surface": "ai_native_research_homepage",
      "states": ["anonymous", "authenticated_unbound", "authenticated_bound", "research_entry_selected", "paper_entry_selected", "grant_entry_selected", "materials_refs_pending", "sending", "runtime_required", "upstream_failed", "quota_exceeded", "auth_required", "api_key_required", "service_unavailable", "network_unreachable"]
    },
    {
      "id": "skills",
      "hash": "#skills",
      "surface": "research_skill_plaza",
      "states": ["readonly_catalog", "research_entry_selected", "paper_entry_selected", "grant_entry_selected", "runtime_required"]
    },
    {
      "id": "workflows",
      "hash": "#workflows",
      "surface": "agentic_research_workflows",
      "states": ["readonly_catalog", "paper_entry_selected", "grant_entry_selected", "materials_refs_pending", "runtime_required"]
    },
    {
      "id": "projects",
      "hash": "#projects",
      "surface": "project_session_refs",
      "states": ["anonymous", "authenticated_unbound", "authenticated_bound"]
    },
    {
      "id": "more",
      "hash": "#more",
      "surface": "empty_overflow_menu",
      "states": ["empty"]
    }
  ],
  "accountStates": ["anonymous", "authenticated_unbound", "authenticated_bound"],
  "chatStates": [
    "idle",
    "research_entry_selected",
    "paper_entry_selected",
    "grant_entry_selected",
    "materials_refs_pending",
    "sending",
    "runtime_required",
    "upstream_failed",
    "quota_exceeded",
    "auth_required",
    "api_key_required",
    "service_unavailable",
    "network_unreachable"
  ],
  "reliabilityModel": {
    "owner": "one-person-lab-web",
    "consumer": "browser_reliability_status_surface",
    "mode": "sanitized_view_model_only",
    "statuses": [
      {
        "state": "auth_required",
        "resultErrorCode": "AUTH_REQUIRED",
        "retryable": false
      },
      {
        "state": "api_key_required",
        "resultErrorCode": "API_KEY_REQUIRED",
        "retryable": false
      },
      {
        "state": "quota_exceeded",
        "resultErrorCode": "CHAT_QUOTA_EXCEEDED",
        "retryable": false
      },
      {
        "state": "upstream_failed",
        "resultErrorCode": "UPSTREAM_CHAT_FAILED",
        "retryable": true
      },
      {
        "state": "service_unavailable",
        "resultErrorCode": "SERVICE_UNAVAILABLE",
        "retryable": true
      },
      {
        "state": "network_unreachable",
        "resultErrorCode": "NETWORK_UNREACHABLE",
        "retryable": true
      }
    ],
    "allowedFields": ["state", "title", "action", "retryable", "details"],
    "forbiddenPayload": [
      "raw_upstream_body",
      "raw_provider_error",
      "api_key",
      "rawApiKey",
      "encryptedApiKey",
      "private_state",
      "private_state_path",
      "database_url",
      "artifact_body"
    ]
  },
  "shellStates": {
    "requiredStates": [
      "public_landing",
      "auth_login_register",
      "home_default",
      "project_library",
      "search_sheet_open",
      "inspector_files",
      "inspector_progress",
      "inspector_output",
      "api_key_required_modal",
      "skill_plaza",
      "workflow_plaza",
      "running_turn",
      "blocked_turn"
    ],
    "defaultAppState": "home_default",
    "layeredGovernance": {
      "productSubject": "ai_native_research_composer_with_project_session_result_workflow",
      "order": ["product_subject", "information_architecture", "first_view_contract", "surface_budget", "interaction_contract", "component_behavior_law", "semantic_tokens"],
      "rule": "components_follow_surface_ownership_not_visual_similarity",
      "noNewTruthFile": true
    },
    "surfaceOwnershipForbidden": {
      "search": ["skill_search", "workflow_search", "prompt_directory", "backend_search_api"],
      "more": ["settings_status_dump", "account_lifecycle", "quota_audit", "provider_base_url", "api_key_form"],
      "account": ["primary_navigation_item", "more_route_panel"],
      "model_selector": ["visible_gateway_url", "base_url_editor"]
    },
    "sideNavigation": {
      "defaultState": "visible",
      "actions": [
        {
          "id": "home",
          "label": "新建对话",
          "kind": "route",
          "targetView": "home",
          "localOnly": true,
          "consumer": "composer_focus",
          "forbiddenApis": []
        },
        {
          "id": "projects",
          "label": "Projects",
          "kind": "route",
          "targetView": "projects",
          "localOnly": true,
          "consumer": "project_library",
          "forbiddenApis": ["/api/projects"]
        },
        {
          "id": "skills",
          "label": "Skill",
          "kind": "route",
          "targetView": "skills",
          "localOnly": true,
          "consumer": "skill_library",
          "forbiddenApis": []
        },
        {
          "id": "workflows",
          "label": "工作流",
          "kind": "route",
          "targetView": "workflows",
          "localOnly": true,
          "consumer": "workflow_library",
          "forbiddenApis": []
        },
        {
          "id": "search",
          "label": "搜索",
          "kind": "sheet",
          "targetView": "home",
          "localOnly": true,
          "consumer": "conversation_history_search",
          "forbiddenApis": ["/api/search"]
        },
        {
          "id": "more",
          "label": "More",
          "kind": "route",
          "targetView": "more",
          "localOnly": true,
          "consumer": "empty_overflow_menu",
          "forbiddenApis": []
        }
      ]
    },
    "routeScopedSurfaces": {
      "home": ["side_navigation", "first_view", "turn_state", "chat_canvas", "runtime_gate"],
      "skills": ["skill_library"],
      "workflows": ["workflow_library"],
      "projects": ["project_library"],
      "more": ["empty_overflow_menu"]
    },
    "librarySurfaces": {
      "skills": { "scopes": ["my_skills", "opl_skills"], "actions": ["import_skill"] },
      "workflows": { "scopes": ["my_workflows", "opl_workflows"], "actions": ["create_workflow", "import_workflow"] },
      "projects": { "scopes": ["my_projects"], "actions": ["create_project"], "forbiddenApis": ["/api/projects"] }
    },
    "inspector": {
      "defaultState": "hidden",
      "tabs": ["files", "progress", "output"],
      "resize": {
        "enabled": true,
        "minWidth": 320,
        "maxWidth": 520
      },
      "placement": "right_resizable_panel",
      "desktopBehavior": "stable_right_work_panel_without_main_overlap",
      "mobileBehavior": "light_bottom_sheet_with_rail_yield",
      "mobileMaxHeightVh": 64,
      "responsivePlacement": {
        "desktop": "right_resizable_panel",
        "tablet": "right_sheet",
        "mobile": "bottom_sheet"
      },
      "mustNotBePrimaryNavigation": true
    },
    "modals": {
      "apiKeyRequired": {
        "state": "api_key_required_modal",
        "primaryAction": "save",
        "primaryActionLabel": "保存",
        "requiredBefore": "chat_send_when_provider_unbound",
        "closeTrigger": ["explicit_close", "escape"],
        "focusReturn": "chat_submit"
      }
    },
    "evidence": {
      "contract": "contracts/web-gui-product-contract.json",
      "shellAdapter": "contracts/web-shell-adapter.json",
      "test": "tests/contract/one-person-lab-web-data.test.mjs"
    }
  },
  "researchTaskIntents": [
    {
      "id": "research_direction",
      "label": "开题/研究方向",
      "marker": "@科研",
      "prompt": "@科研 帮我拆解研究方向、问题和下一步计划",
      "runtimePolicy": "ordinary_chat_fallback",
      "expectedChatState": "research_entry_selected",
      "consumer": "research_user_prompt"
    },
    {
      "id": "paper_question",
      "label": "论文问题",
      "marker": "@论文",
      "prompt": "@论文 生成研究选题、问题拆解和证据计划",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "paper_entry_selected",
      "consumer": "research_user_prompt"
    },
    {
      "id": "grant_plan",
      "label": "基金计划",
      "marker": "@基金",
      "prompt": "@基金 帮我拆解标书结构、研究目标和执行路径",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "grant_entry_selected",
      "consumer": "research_user_prompt"
    },
    {
      "id": "review_map",
      "label": "综述地图",
      "marker": "@综述",
      "prompt": "@综述 帮我整理综述结构、证据线索和引用计划",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "materials_refs_pending",
      "consumer": "research_user_prompt"
    },
    {
      "id": "materials_refs",
      "label": "材料线索",
      "marker": "@文件",
      "prompt": "@文件 整理材料引用和交付物 refs",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "materials_refs_pending",
      "consumer": "research_user_prompt"
    }
  ],
  "pageStateRules": [
    {
      "when": "anonymous",
      "requiredApi": ["/api/session/current"],
      "allowedAction": "show_login_register"
    },
    {
      "when": "authenticated_unbound",
      "requiredApi": ["/api/session/current", "/api/settings/model-provider"],
      "allowedAction": "show_provider_binding"
    },
    {
      "when": "authenticated_bound",
      "requiredApi": ["/api/session/current", "/api/settings/model-provider", "/api/chat/conversations"],
      "allowedAction": "allow_research_capability_entry"
    },
    {
      "when": "research_entry_selected",
      "requiredApi": ["/api/chat"],
      "allowedAction": "send_research_capability_prompt"
    },
    {
      "when": "paper_entry_selected",
      "requiredApi": ["/api/chat"],
      "allowedAction": "show_runtime_gate_for_paper_workflow"
    },
    {
      "when": "grant_entry_selected",
      "requiredApi": ["/api/chat"],
      "allowedAction": "show_runtime_gate_for_grant_workflow"
    },
    {
      "when": "materials_refs_pending",
      "requiredApi": ["/api/medopl/materials-deliverables/projection"],
      "allowedAction": "show_refs_only_material_projection"
    },
    {
      "when": "runtime_required",
      "requiredApi": ["/api/chat"],
      "allowedAction": "show_medopl_runtime_gate"
    }
  ],
  "localReadinessScenario": {
    "requiresProductionSecrets": false,
    "observableSelectors": [
      "[data-chat-form]",
      "[data-chat-log]",
      "[data-side-navigation]",
      "[data-first-view]",
      "[data-starter-chips]",
      "[data-register-button]",
      "[data-login-button]",
      "[data-provider-form]",
      "[data-more-overflow]",
      "[data-project-library]",
      "[data-search-sheet]",
      "[data-conversation-search]",
      "[data-conversation-history]",
      "[data-conversation-empty]",
      "[data-model-selector]",
      "[data-overlay-close]",
      "[data-runtime-gate]",
      "[data-research-launcher]",
      "[data-research-task]",
      "[data-capability-marker]",
      "[data-capability-mode]",
      "[data-research-result]",
      "[data-research-result-section]",
      "[data-runtime-task-card]",
      "[data-reliability-status]",
      "[data-reliability-title]",
      "[data-reliability-action]",
      "[data-reliability-details]"
    ],
    "steps": [
      {
        "id": "anonymous_shell",
        "route": "home",
        "expectedState": "anonymous",
        "evidence": "tests/smoke/web-shell.test.mjs"
      },
      {
        "id": "register",
        "route": "home",
        "requiredApi": "/api/auth/register",
        "expectedState": "authenticated_unbound",
        "evidence": "tests/contract/one-person-lab-chat-upstream.test.mjs"
      },
      {
        "id": "login",
        "route": "home",
        "requiredApi": "/api/auth/login",
        "expectedState": "authenticated_unbound",
        "evidence": "tests/contract/one-person-lab-chat-upstream.test.mjs"
      },
      {
        "id": "current_session",
        "route": "home",
        "requiredApi": "/api/session/current",
        "expectedState": "authenticated_unbound",
        "evidence": "tests/contract/one-person-lab-chat-upstream.test.mjs"
      },
      {
        "id": "browser_session_bootstrap",
        "route": "home",
        "requiredApi": "/api/session/current",
        "expectedState": "authenticated_bound",
        "evidence": "tests/contract/one-person-lab-web-data.test.mjs"
      },
      {
        "id": "api_key_binding",
        "route": "home",
        "requiredApi": "/api/settings/model-provider",
        "expectedState": "authenticated_bound",
        "evidence": "tests/contract/one-person-lab-chat-upstream.test.mjs"
      },
      {
        "id": "research_task_template_selected",
        "route": "home",
        "expectedState": "research_entry_selected",
        "evidence": "tests/browser/research-main-path.browser.test.mjs"
      },
      {
        "id": "research_skill_launcher",
        "route": "home",
        "expectedState": "research_entry_selected",
        "evidence": "tests/smoke/web-shell.test.mjs"
      },
      {
        "id": "ordinary_chat_fallback",
        "route": "home",
        "requiredApi": "/api/chat",
        "expectedState": "idle",
        "evidence": "tests/contract/one-person-lab-chat-upstream.test.mjs"
      },
      {
        "id": "quota_exceeded",
        "route": "home",
        "requiredApi": "/api/chat",
        "expectedState": "quota_exceeded",
        "evidence": "tests/contract/one-person-lab-chat-upstream.test.mjs"
      },
      {
        "id": "paper_runtime_gate",
        "route": "home",
        "requiredApi": "/api/chat",
        "expectedState": "runtime_required",
        "evidence": "tests/contract/one-person-lab-chat-upstream.test.mjs"
      },
      {
        "id": "grant_runtime_gate",
        "route": "home",
        "requiredApi": "/api/chat",
        "expectedState": "runtime_required",
        "evidence": "tests/contract/one-person-lab-chat-upstream.test.mjs"
      },
      {
        "id": "conversation_history_search_visible",
        "route": "home",
        "expectedState": "idle",
        "evidence": "tests/smoke/web-shell.test.mjs"
      },
      {
        "id": "more_empty_overflow_visible",
        "route": "more",
        "expectedState": "empty",
        "evidence": "tests/smoke/web-shell.test.mjs"
      },
      {
        "id": "reliability_status_visible",
        "route": "home",
        "expectedState": "upstream_failed",
        "evidence": "tests/contract/one-person-lab-web-data.test.mjs"
      },
      {
        "id": "sanitized_audit",
        "route": "home",
        "requiredApi": "/api/account/audit-events",
        "expectedState": "authenticated_bound",
        "evidence": "tests/contract/one-person-lab-chat-upstream.test.mjs"
      }
    ]
  },
  "structuredResultShape": {
    "owner": "one-person-lab-web",
    "consumer": "research_user_chat_result",
    "mode": "ui_view_model_only",
    "sections": ["research_plan", "evidence_refs", "next_steps"],
    "primarySurface": "structured_research_artifact_card",
    "rawAssistantTranscriptForStructuredResult": "forbidden",
    "maxRawAssistantMessagesPerStructuredResult": 0,
    "runtimeGateCard": "refs_only_medopl_deeplink",
    "forbiddenPayload": ["artifact_body", "private_state_path", "mutation_result", "raw_provider_secret"]
  }
}
