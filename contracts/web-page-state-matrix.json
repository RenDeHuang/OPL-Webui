{
  "schemaVersion": 1,
  "productId": "one-person-lab-web",
  "productLayers": [
    { "id": "public_growth_layer", "status": "current_public_surface", "surfaceOwner": "public_growth_pages", "defaultAudience": "anonymous_user" },
    { "id": "account_based_user_product_layer", "status": "current_primary", "surfaceOwner": "account_based_web_app", "defaultAudience": "authenticated_research_user" },
    { "id": "minimal_admin_ops_layer", "status": "active_slice", "surfaceOwner": "operator_only_controls", "defaultAudience": "operator" }
  ],
  "minimalAdminOpsLayer": {
    "registrationMode": { "default": "open", "allowed": ["open", "invite_only", "allowlist", "disabled"] },
    "userStatus": { "allowed": ["active", "disabled"] },
    "activeSlice": "admin_ops_registration_policy_and_user_status_v0",
    "firstPhaseRouteOptions": ["operator_only_api", "/_ops"],
    "operatorAuth": "operator_token_required",
    "apiRoutes": [
      "GET /api/ops/registration-policy",
      "PUT /api/ops/registration-policy",
      "GET /api/ops/users",
      "POST /api/ops/users/{userId}/status"
    ],
    "disabledUserDenials": ["login", "session_current", "chat", "api_key_binding", "user_product_path"],
    "requiresAuditForAdminMutation": true,
    "forbiddenSurfaces": ["payment", "pricing", "subscription", "invoice", "refund", "team_rbac", "support_impersonation"],
    "doesNotProve": ["full SaaS", "payment lifecycle", "team/RBAC lifecycle", "HA", "runtime sync", "runtime execution"]
  },
  "publicGrowthLayer": {
    "owner": "one-person-lab-web",
    "defaultAudience": "anonymous_user",
    "requiredSections": ["hero", "task_entries", "outputs", "audience", "trust_boundary", "start_path"],
    "observableSelectors": [
      "[data-public-growth-layer]",
      "[data-public-hero]",
      "[data-public-task-section]",
      "[data-public-output-section]",
      "[data-public-audience-section]",
      "[data-public-trust-section]",
      "[data-public-start-path]",
      "[data-public-task-entry]",
      "[data-public-start-cta]"
    ],
    "startPath": {
      "anonymousAction": "open_login_register_popover",
      "pendingTaskStorage": "document.body.dataset.pendingPublicTaskIntent",
      "afterAuth": "restore_selected_task_prompt_and_focus_composer"
    },
    "cannotClaim": ["authenticated task success", "runtime execution", "artifact body authority", "full SaaS", "payment/team/RBAC/HA"]
  },
  "routes": [
    {
      "id": "home",
      "hash": "",
      "surface": "ai_native_research_homepage",
      "states": ["anonymous", "authenticated_unbound", "authenticated_bound", "research_entry_selected", "paper_entry_selected", "grant_entry_selected", "materials_refs_pending", "presentation_entry_selected", "book_entry_selected", "sending", "runtime_required", "upstream_failed", "quota_exceeded", "auth_required", "api_key_required", "service_unavailable", "network_unreachable"]
    },
    {
      "id": "skills",
      "hash": "#skills",
      "surface": "research_skill_plaza",
      "states": ["readonly_catalog", "research_entry_selected", "paper_entry_selected", "grant_entry_selected", "presentation_entry_selected", "book_entry_selected", "runtime_required"]
    },
    {
      "id": "workflows",
      "hash": "#workflows",
      "surface": "agentic_research_workflows",
      "states": ["readonly_catalog", "paper_entry_selected", "grant_entry_selected", "materials_refs_pending", "presentation_entry_selected", "book_entry_selected", "runtime_required"]
    },
    {
      "id": "projects",
      "hash": "#projects",
      "surface": "project_session_refs",
      "states": ["anonymous", "authenticated_unbound", "authenticated_bound"]
    },
    {
      "id": "more",
      "hash": "#more",
      "surface": "empty_overflow_menu",
      "states": ["empty"]
    }
  ],
  "accountStates": ["anonymous", "authenticated_unbound", "authenticated_bound"],
  "userMainPathStates": {
    "mode": "account_based_web_app_main_path_v1",
    "owner": "one-person-lab-web",
    "consumer": "research_user",
    "orderedStates": [
      { "id": "open_web", "route": "home", "requiredState": "anonymous", "requiredSurface": "public_landing" },
      { "id": "login", "route": "home", "requiredState": "authenticated_unbound", "requiredSurface": "auth_login_register" },
      { "id": "bind_key_or_account_capability", "route": "home", "requiredState": "authenticated_bound", "requiredSurface": "api_key_required_modal" },
      { "id": "choose_task", "route": "home", "requiredState": "research_entry_selected", "requiredSurface": "research_task_launcher" },
      { "id": "view_result_or_gate", "route": "home", "requiredState": "runtime_required", "requiredSurface": "turn_state" },
      { "id": "view_progress_refs", "route": "home", "requiredState": "progress_refs_readonly", "requiredSurface": "inspector_progress" },
      { "id": "view_deliverable_refs", "route": "home", "requiredState": "deliverable_refs_readonly", "requiredSurface": "inspector_output" },
      { "id": "view_blocker_next_step", "route": "home", "requiredState": "service_unavailable", "requiredSurface": "reliability_status" },
      { "id": "continue_via_deeplink", "route": "home", "requiredState": "medopl_authorized", "requiredSurface": "runtime_gate" }
    ],
    "evidence": [
      "tests/contract/one-person-lab-web-data.test.mjs",
      "tests/browser/research-main-path.browser.test.mjs"
    ],
    "cannotClaim": [
      "Web-side runtime execution",
      "artifact body authority",
      "payment lifecycle",
      "team/RBAC lifecycle"
    ]
  },
  "chatStates": [
    "idle",
    "research_entry_selected",
    "paper_entry_selected",
    "grant_entry_selected",
    "materials_refs_pending",
    "presentation_entry_selected",
    "book_entry_selected",
    "sending",
    "runtime_required",
    "upstream_failed",
    "quota_exceeded",
    "auth_required",
    "api_key_required",
    "service_unavailable",
    "network_unreachable"
  ],
  "medoplCapabilityStates": {
    "mode": "authorized_capability_projection_without_web_authority",
    "states": [
      "medopl_not_authorized",
      "medopl_authorized",
      "runtime_status_readonly",
      "storage_status_readonly",
      "progress_refs_readonly",
      "deliverable_refs_readonly"
    ],
    "ownedExperience": [
      "entry",
      "authorization_status",
      "runtime_gate_bridge",
      "run_intent_submission",
      "readonly_projection",
      "progress_refs_projection",
      "deliverable_refs_projection",
      "billing_ledger_refs_projection",
      "deeplink",
      "fail_closed_gate"
    ],
    "runtimeRequiredFlow": {
      "triggerMarkers": ["@论文", "@基金", "@综述", "@文件", "@PPT", "@书"],
      "gateRoute": "POST /api/opl/runtime-gate",
      "runRoute": "POST /api/opl/runs",
      "readyPolicy": "medopl_account_resource_state_ready_required_before_run",
      "runtimeAdmission": {
        "mode": "medopl_account_resource_state_driven",
        "readyWhen": [
          "package_or_plan_active",
          "credit_or_billing_ok",
          "compute_resource_open",
          "storage_space_open",
          "workspace_runtime_storage_binding_bound"
        ],
        "notProductPolicy": [
          "selected_user",
          "test_account",
          "canary_account",
          "hardcoded_account_allowlist",
          "MEDOPL_API_BASE_URL"
        ]
      },
      "notReadyStates": [
        "api_key_required",
        "package_required",
        "compute_required",
        "storage_required",
        "workspace_runtime_binding_required",
        "billing_blocked",
        "release_required",
        "audit_required",
        "medopl_endpoint_required"
      ],
      "operatorDeploymentBlockerStates": [
        "medopl_endpoint_required"
      ],
      "readyProjection": ["refs", "progress_refs", "deliverable_refs", "deeplink"],
      "forbiddenProjection": ["artifact_body", "domain_verdict", "billing_truth", "storage_mutation"]
    },
    "forbiddenClaims": [
      "web_runtime_execution",
      "web_storage_truth",
      "artifact_body_authority",
      "node_pool_lifecycle"
    ],
    "authorityOwner": "MedOPL / OPL Framework",
    "contractBoundary": "runtime/storage are target user capabilities through MedOPL authorization; Web page state may show authorization, status, refs, and links only."
  },
  "reliabilityModel": {
    "owner": "one-person-lab-web",
    "consumer": "browser_reliability_status_surface",
    "mode": "sanitized_view_model_only",
    "statuses": [
      {
        "state": "auth_required",
        "resultErrorCode": "AUTH_REQUIRED",
        "retryable": false
      },
      {
        "state": "api_key_required",
        "resultErrorCode": "API_KEY_REQUIRED",
        "retryable": false
      },
      {
        "state": "quota_exceeded",
        "resultErrorCode": "CHAT_QUOTA_EXCEEDED",
        "retryable": false
      },
      {
        "state": "runtime_required",
        "resultErrorCode": "RUNTIME_REQUIRED",
        "retryable": false
      },
      {
        "state": "runtime_required",
        "resultErrorCode": "RUNTIME_GATE_BLOCKED",
        "retryable": false
      },
      {
        "state": "runtime_required",
        "resultErrorCode": "MEDOPL_ENDPOINT_REQUIRED",
        "retryable": false
      },
      {
        "state": "upstream_failed",
        "resultErrorCode": "UPSTREAM_CHAT_FAILED",
        "retryable": true
      },
      {
        "state": "service_unavailable",
        "resultErrorCode": "SERVICE_UNAVAILABLE",
        "retryable": true
      },
      {
        "state": "network_unreachable",
        "resultErrorCode": "NETWORK_UNREACHABLE",
        "retryable": true
      }
    ],
    "allowedFields": ["state", "title", "action", "retryable", "details"],
    "forbiddenPayload": [
      "raw_upstream_body",
      "raw_provider_error",
      "api_key",
      "rawApiKey",
      "encryptedApiKey",
      "private_state",
      "private_state_path",
      "database_url",
      "artifact_body"
    ]
  },
  "shellStates": {
    "requiredStates": [
      "public_landing",
      "auth_login_register",
      "home_default",
      "project_library",
      "search_sheet_open",
      "inspector_files",
      "inspector_progress",
      "inspector_output",
      "api_key_required_modal",
      "skill_plaza",
      "workflow_plaza",
      "running_turn",
      "blocked_turn"
    ],
    "defaultAppState": "home_default",
    "layeredGovernance": {
      "productSubject": "ai_native_research_composer_with_project_session_result_workflow",
      "order": ["product_subject", "information_architecture", "first_view_contract", "surface_budget", "interaction_contract", "component_behavior_law", "semantic_tokens"],
      "rule": "components_follow_surface_ownership_not_visual_similarity",
      "noNewTruthFile": true
    },
    "surfaceOwnershipForbidden": {
      "search": ["skill_search", "workflow_search", "prompt_directory", "backend_search_api"],
      "more": ["settings_status_dump", "account_lifecycle", "quota_audit", "provider_base_url", "api_key_form"],
      "account": ["primary_navigation_item", "more_route_panel"],
      "model_selector": ["visible_gateway_url", "base_url_editor"]
    },
    "surfaceInteractionAcceptance": {
      "search": {
        "openTrigger": "side_nav_search",
        "closeTrigger": ["explicit_close", "escape", "outside_click", "route_change"],
        "focusReturn": "side_nav_search",
        "emptyState": "conversation_history_empty",
        "forbiddenContent": ["skills", "workflows", "prompts", "provider_settings"]
      },
      "more": {
        "openTrigger": "side_nav_more",
        "closeTrigger": ["route_change"],
        "emptyState": "empty_overflow",
        "forbiddenContent": ["settings", "account_lifecycle", "quota", "provider_base_url", "api_key_form"]
      },
      "account": {
        "openTrigger": "bottom_avatar",
        "closeTrigger": ["explicit_close", "escape", "outside_click", "route_change"],
        "focusReturn": "bottom_avatar",
        "placement": "bottom_avatar_popover"
      },
      "model_selector": {
        "openTrigger": "composer_model_choice",
        "closeTrigger": ["selection", "escape", "outside_click"],
        "forbiddenContent": ["gateway_url", "base_url_editor"]
      },
      "inspector": {
        "desktop": "stable_right_work_panel",
        "mobile": "light_bottom_sheet",
        "focusReturn": "right_utility_rail"
      }
    },
    "sideNavigation": {
      "defaultState": "visible",
      "actions": [
        {
          "id": "home",
          "label": "新建对话",
          "kind": "route",
          "targetView": "home",
          "localOnly": true,
          "consumer": "composer_focus",
          "forbiddenApis": []
        },
        {
          "id": "projects",
          "label": "Projects",
          "kind": "route",
          "targetView": "projects",
          "localOnly": true,
          "consumer": "project_library",
          "forbiddenApis": ["/api/projects"]
        },
        {
          "id": "skills",
          "label": "Skill",
          "kind": "route",
          "targetView": "skills",
          "localOnly": true,
          "consumer": "skill_library",
          "forbiddenApis": []
        },
        {
          "id": "workflows",
          "label": "工作流",
          "kind": "route",
          "targetView": "workflows",
          "localOnly": true,
          "consumer": "workflow_library",
          "forbiddenApis": []
        },
        {
          "id": "search",
          "label": "搜索",
          "kind": "sheet",
          "targetView": "home",
          "localOnly": true,
          "consumer": "conversation_history_search",
          "forbiddenApis": ["/api/search"]
        },
        {
          "id": "more",
          "label": "More",
          "kind": "route",
          "targetView": "more",
          "localOnly": true,
          "consumer": "empty_overflow_menu",
          "forbiddenApis": []
        }
      ]
    },
    "routeScopedSurfaces": {
      "home": ["side_navigation", "first_view", "turn_state", "chat_canvas", "runtime_gate"],
      "skills": ["skill_library"],
      "workflows": ["workflow_library"],
      "projects": ["project_library"],
      "more": ["empty_overflow_menu"]
    },
    "librarySurfaces": {
      "skills": { "scopes": ["my_skills", "opl_skills"], "actions": ["import_skill"] },
      "workflows": { "scopes": ["my_workflows", "opl_workflows"], "actions": ["create_workflow", "import_workflow"] },
      "projects": { "scopes": ["my_projects"], "actions": ["create_project"], "forbiddenApis": ["/api/projects"] }
    },
    "inspector": {
      "defaultState": "hidden",
      "tabs": ["files", "progress", "output"],
      "resize": {
        "enabled": true,
        "minWidth": 320,
        "maxWidth": 520
      },
      "placement": "right_resizable_panel",
      "desktopBehavior": "stable_right_work_panel_without_main_overlap",
      "mobileBehavior": "light_bottom_sheet_with_rail_yield",
      "mobileMaxHeightVh": 64,
      "responsivePlacement": {
        "desktop": "right_resizable_panel",
        "tablet": "right_sheet",
        "mobile": "bottom_sheet"
      },
      "mustNotBePrimaryNavigation": true
    },
    "modals": {
      "apiKeyRequired": {
        "state": "api_key_required_modal",
        "primaryAction": "save",
        "primaryActionLabel": "保存",
        "requiredBefore": "chat_send_when_provider_unbound",
        "closeTrigger": ["explicit_close", "escape"],
        "focusReturn": "chat_submit"
      }
    },
    "evidence": {
      "contract": "contracts/web-gui-product-contract.json",
      "shellAdapter": "contracts/web-shell-adapter.json",
      "test": "tests/contract/one-person-lab-web-data.test.mjs"
    }
  },
  "researchTaskIntents": [
    {
      "id": "research_direction",
      "label": "开题/研究方向",
      "marker": "@科研",
      "prompt": "@科研 帮我拆解研究方向、问题和下一步计划",
      "runtimePolicy": "ordinary_chat_fallback",
      "expectedChatState": "research_entry_selected",
      "consumer": "research_user_prompt"
    },
    {
      "id": "paper_question",
      "label": "论文问题",
      "marker": "@论文",
      "prompt": "@论文 生成研究选题、问题拆解和证据计划",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "paper_entry_selected",
      "consumer": "research_user_prompt"
    },
    {
      "id": "grant_plan",
      "label": "基金计划",
      "marker": "@基金",
      "prompt": "@基金 帮我拆解标书结构、研究目标和执行路径",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "grant_entry_selected",
      "consumer": "research_user_prompt"
    },
    {
      "id": "review_map",
      "label": "综述地图",
      "marker": "@综述",
      "prompt": "@综述 帮我整理综述结构、证据线索和引用计划",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "materials_refs_pending",
      "consumer": "research_user_prompt"
    },
    {
      "id": "materials_refs",
      "label": "材料线索",
      "marker": "@文件",
      "prompt": "@文件 整理材料引用和交付物 refs",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "materials_refs_pending",
      "consumer": "research_user_prompt"
    },
    {
      "id": "presentation_foundry",
      "label": "演示/PPT",
      "marker": "@PPT",
      "prompt": "@PPT 规划研究演示结构、证据线和交付物 refs",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "presentation_entry_selected",
      "consumer": "research_user_prompt"
    },
    {
      "id": "book_foundry",
      "label": "写书/长稿",
      "marker": "@书",
      "prompt": "@书 规划书稿结构、章节路线和资料 refs",
      "runtimePolicy": "runtime_gate",
      "expectedChatState": "book_entry_selected",
      "consumer": "research_user_prompt"
    }
  ],
  "pageStateRules": [
    {
      "when": "anonymous",
      "requiredApi": ["/api/session/current"],
      "allowedAction": "show_login_register"
    },
    {
      "when": "authenticated_unbound",
      "requiredApi": ["/api/session/current", "/api/settings/model-provider"],
      "allowedAction": "show_provider_binding"
    },
    {
      "when": "authenticated_bound",
      "requiredApi": ["/api/session/current", "/api/settings/model-provider", "/api/chat/conversations"],
      "allowedAction": "allow_research_capability_entry"
    },
    {
      "when": "research_entry_selected",
      "requiredApi": ["/api/chat"],
      "allowedAction": "send_research_capability_prompt"
    },
    {
      "when": "paper_entry_selected",
      "requiredApi": ["/api/chat"],
      "allowedAction": "show_runtime_gate_for_paper_workflow"
    },
    {
      "when": "grant_entry_selected",
      "requiredApi": ["/api/chat"],
      "allowedAction": "show_runtime_gate_for_grant_workflow"
    },
    {
      "when": "materials_refs_pending",
      "requiredApi": ["/api/medopl/materials-deliverables/projection"],
      "allowedAction": "show_refs_only_material_projection"
    },
    {
      "when": "presentation_entry_selected",
      "requiredApi": ["/api/chat"],
      "allowedAction": "show_runtime_gate_for_presentation_foundry"
    },
    {
      "when": "book_entry_selected",
      "requiredApi": ["/api/chat"],
      "allowedAction": "show_runtime_gate_for_book_foundry"
    },
    {
      "when": "runtime_required",
      "requiredApi": ["/api/chat"],
      "allowedAction": "show_medopl_runtime_gate"
    }
  ],
  "localReadinessScenario": {
    "requiresProductionSecrets": false,
    "observableSelectors": [
      "[data-chat-form]",
      "[data-chat-log]",
      "[data-side-navigation]",
      "[data-first-view]",
      "[data-starter-chips]",
      "[data-register-button]",
      "[data-login-button]",
      "[data-provider-form]",
      "[data-more-overflow]",
      "[data-project-library]",
      "[data-search-sheet]",
      "[data-conversation-search]",
      "[data-conversation-history]",
      "[data-conversation-empty]",
      "[data-model-selector]",
      "[data-overlay-close]",
      "[data-runtime-gate]",
      "[data-research-launcher]",
      "[data-research-task]",
      "[data-capability-marker]",
      "[data-capability-mode]",
      "[data-research-result]",
      "[data-research-result-section]",
      "[data-runtime-task-card]",
      "[data-reliability-status]",
      "[data-reliability-title]",
      "[data-reliability-action]",
      "[data-reliability-details]"
    ],
