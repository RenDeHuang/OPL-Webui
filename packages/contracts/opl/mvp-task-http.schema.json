{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl-webui.local/contracts/opl/mvp-task-http.schema.json",
  "title": "OPL WebUI MVP Task HTTP Contract",
  "type": "object",
  "required": ["tenantId", "workspaceId", "userId", "prompt"],
  "additionalProperties": false,
  "properties": {
    "tenantId": { "type": "string", "minLength": 1 },
    "workspaceId": { "type": "string", "minLength": 1 },
    "userId": { "type": "string", "minLength": 1 },
    "prompt": { "type": "string", "minLength": 1 },
    "intent": {
      "type": "string",
      "enum": ["research", "grant", "presentation", "general"]
    }
  }
}
