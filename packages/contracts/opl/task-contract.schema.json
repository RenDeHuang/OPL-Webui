{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl-webui.local/contracts/opl/task-contract.schema.json",
  "title": "OPL WebUI Task Contract",
  "type": "object",
  "required": ["taskId", "tenantId", "workspaceId", "intent", "status"],
  "additionalProperties": false,
  "properties": {
    "taskId": { "type": "string", "minLength": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "workspaceId": { "type": "string", "minLength": 1 },
    "intent": {
      "type": "string",
      "enum": ["research", "grant", "presentation", "general"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "queued", "running", "needs_review", "completed", "failed", "blocked"]
    },
    "commandPolicyId": { "type": "string" },
    "artifactRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
