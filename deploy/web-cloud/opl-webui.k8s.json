{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {
      "apiVersion": "v1",
      "kind": "Namespace",
      "metadata": {
        "name": "opl-webui",
        "labels": {
          "app.kubernetes.io/name": "opl-webui"
        }
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "opl-webui-control-plane",
        "namespace": "opl-webui",
        "labels": {
          "app.kubernetes.io/name": "opl-webui"
        }
      },
      "spec": {
        "replicas": 2,
        "strategy": {
          "type": "RollingUpdate",
          "rollingUpdate": {
            "maxUnavailable": 0,
            "maxSurge": 1
          }
        },
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-webui"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "opl-webui"
            }
          },
          "spec": {
            "imagePullSecrets": [
              {
                "name": "tcr-pull-secret"
              }
            ],
            "nodeSelector": {
              "medopl.cn/workload": "webui"
            },
            "topologySpreadConstraints": [
              {
                "maxSkew": 1,
                "topologyKey": "kubernetes.io/hostname",
                "whenUnsatisfiable": "DoNotSchedule",
                "labelSelector": {
                  "matchLabels": {
                    "app.kubernetes.io/name": "opl-webui"
                  }
                }
              }
            ],
            "affinity": {
              "podAntiAffinity": {
                "preferredDuringSchedulingIgnoredDuringExecution": [
                  {
                    "weight": 100,
                    "podAffinityTerm": {
                      "topologyKey": "kubernetes.io/hostname",
                      "labelSelector": {
                        "matchLabels": {
                          "app.kubernetes.io/name": "opl-webui"
                        }
                      }
                    }
                  }
                ]
              }
            },
            "containers": [
              {
                "name": "control-plane",
                "image": "uswccr.ccs.tencentyun.com/webopl/opl-webui:30a3249",
                "ports": [
                  {
                    "name": "http",
                    "containerPort": 4173
                  }
                ],
                "env": [
                  {
                    "name": "HOST",
                    "value": "0.0.0.0"
                  },
                  {
                    "name": "PORT",
                    "value": "4173"
                  },
                  {
                    "name": "OPL_WEBUI_ENV",
                    "value": "web_cloud"
                  },
                  {
                    "name": "OPL_CLI_PATH",
                    "value": "/opt/opl/bin/opl"
                  },
                  {
                    "name": "OPL_DATABASE_URL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-webui-postgres",
                        "key": "OPL_DATABASE_URL"
                      }
                    }
                  },
                  {
                    "name": "OPL_TENANT_AUTH_SECRET",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-webui-auth",
                        "key": "OPL_TENANT_AUTH_SECRET"
                      }
                    }
                  },
                  {
                    "name": "OPL_SESSION_SECRET",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-webui-auth",
                        "key": "OPL_SESSION_SECRET"
                      }
                    }
                  },
                  {
                    "name": "OPL_API_KEY_ENCRYPTION_SECRET",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-webui-auth",
                        "key": "OPL_API_KEY_ENCRYPTION_SECRET"
                      }
                    }
                  },
                  {
                    "name": "OPL_CHAT_MODEL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-webui-auth",
                        "key": "OPL_CHAT_MODEL"
                      }
                    }
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/readyz",
                    "port": 4173
                  }
                },
                "livenessProbe": {
                  "httpGet": {
                    "path": "/healthz",
                    "port": 4173
                  }
                },
                "resources": {
                  "requests": {
                    "cpu": "100m",
                    "memory": "128Mi"
                  },
                  "limits": {
                    "cpu": "500m",
                    "memory": "512Mi"
                  }
                }
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "policy/v1",
      "kind": "PodDisruptionBudget",
      "metadata": {
        "name": "opl-webui-control-plane",
        "namespace": "opl-webui"
      },
      "spec": {
        "minAvailable": 1,
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-webui"
          }
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "opl-webui-control-plane",
        "namespace": "opl-webui"
      },
      "spec": {
        "type": "NodePort",
        "selector": {
          "app.kubernetes.io/name": "opl-webui"
        },
        "ports": [
          {
            "name": "http",
            "port": 4173,
            "targetPort": 4173,
            "nodePort": 32258
          }
        ]
      }
    },
    {
      "apiVersion": "networking.k8s.io/v1",
      "kind": "Ingress",
      "metadata": {
        "name": "opl-webui",
        "namespace": "opl-webui"
      },
      "spec": {
        "ingressClassName": "qcloud",
        "tls": [
          {
            "hosts": [
              "opl.medopl.cn"
            ],
            "secretName": "opl-webui-tls"
          }
        ],
        "rules": [
          {
            "host": "opl.medopl.cn",
            "http": {
              "paths": [
                {
                  "path": "/",
                  "pathType": "Prefix",
                  "backend": {
                    "service": {
                      "name": "opl-webui-control-plane",
                      "port": {
                        "number": 4173
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
