# OPL-Webui deploy example environment.
# Copy values into an untracked environment file for local or standalone use.
# Never commit real secrets.

HOST=0.0.0.0
PORT=4173
OPL_WEBUI_ENV=development

# External Webui control-plane state. MedOPL owns canonical runtime/resource/storage/billing/payment truth.
OPL_DATABASE_URL=<external-webui-postgres-dsn-from-secret-manager>
OPL_DATABASE_MAX_OPEN_CONNS=10
OPL_DATABASE_MAX_IDLE_CONNS=5
OPL_DATABASE_CONN_MAX_LIFETIME_SECONDS=300

# Secrets must be generated per environment.
OPL_SESSION_SECRET=<at-least-32-bytes-session-secret>
OPL_API_KEY_ENCRYPTION_SECRET=<at-least-32-bytes-api-key-encryption-secret>
OPL_TENANT_AUTH_SECRET=<at-least-32-bytes-tenant-auth-secret>

# Chat and bridge config.
OPL_CHAT_MODEL=gpt-5.5
OPL_CHAT_UPSTREAM_TIMEOUT_SECONDS=60
MEDOPL_API_BASE_URL=<medopl-api-base-url>
OPL_CLI_PATH=/opt/opl/bin/opl

# Optional local-only diagnostics.
OPL_ADMIN_OPERATOR_TOKEN=<local-dev-only-operator-token>
